{
  "_comment": "OpenClaw MCP 配置示例 - 复制到 ~/.openclaw/openclaw.json",
  "_note": "请将 /home/user/.rhmcp 替换为实际安装路径",
  "_note2": "API Key 建议放在 ~/.rhmcp/.env 文件中",

  "mcp": {
    "servers": {
      "rhmcp": {
        "command": "node",
        "args": ["/home/user/.rhmcp/dist/server/index.js", "--stdio"],
        "env": {
          "RHMCP_CONFIG": "/home/user/.rhmcp"
        }
      }
    }
  },
  "skills": {
    "entries": {
      "rhmcp-skill": {
        "enabled": true,
        "path": "/home/user/.rhmcp/skills/openclaw"
      }
    }
  }
}
