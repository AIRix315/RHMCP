{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "service.schema.json",
  "title": "RHMCP Service Configuration",
  "description": "Service configuration for RunningHub MCP Server",
  "type": "object",
  "properties": {
    "baseUrl": {
      "type": "string",
      "enum": ["auto", "www.runninghub.cn", "www.runninghub.ai"],
      "default": "auto",
      "description": "RunningHub API endpoint. Use 'auto' for automatic detection, or specify manually."
    },
    "maxConcurrent": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Maximum concurrent requests to RunningHub API"
    },
    "storage": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["local", "network", "auto", "none"],
          "default": "local",
          "description": "Storage mode for generated files"
        },
        "path": {
          "type": "string",
          "default": "./output",
          "description": "Local storage path (for 'local' mode)"
        },
        "cloudConfig": {
          "type": "object",
          "description": "Cloud storage configuration (for 'network' mode)",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["baidu", "aliyun", "aws", "google"]
            },
            "accessKey": { "type": "string" },
            "secretKey": { "type": "string" },
            "bucket": { "type": "string" },
            "region": { "type": "string" }
          },
          "required": ["provider", "accessKey", "secretKey", "bucket"]
        }
      },
      "required": ["mode"]
    },
    "retry": {
      "type": "object",
      "properties": {
        "maxRetries": {
          "type": "integer",
          "minimum": 0,
          "default": 3,
          "description": "Maximum retry attempts"
        },
        "maxWaitTime": {
          "type": "integer",
          "minimum": 1,
          "default": 600,
          "description": "Maximum wait time in seconds"
        },
        "interval": {
          "type": "integer",
          "minimum": 1,
          "default": 5,
          "description": "Retry interval in seconds"
        }
      },
      "required": ["maxRetries", "maxWaitTime", "interval"]
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "description": "Log level"
        }
      },
      "required": ["level"]
    },
    "modelRules": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "object",
          "description": "Model-specific rules",
          "additionalProperties": {
            "type": "object"
          }
        },
        "defaultLanguage": {
          "type": "string",
          "default": "zh",
          "description": "Default language for prompts"
        }
      },
      "required": ["rules"]
    }
  },
  "required": ["baseUrl"],
  "additionalProperties": false
}