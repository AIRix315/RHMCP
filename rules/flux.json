{
  "name": "flux",
  "description": "FLUX 图像生成模型规则",
  "category": "image",
  "constraints": {
    "width": {
      "min": 256,
      "max": 2048,
      "step": 8,
      "description": "图片宽度，建议为8的倍数"
    },
    "height": {
      "min": 256,
      "max": 2048,
      "step": 8,
      "description": "图片高度，建议为8的倍数"
    },
    "steps": {
      "min": 1,
      "max": 50,
      "description": "生成步数"
    },
    "guidance_scale": {
      "min": 1,
      "max": 20,
      "description": "引导强度"
    }
  },
  "promptSpec": {
    "format": "natural",
    "languages": ["en", "zh"],
    "preferredLanguage": "en",
    "maxLength": 1500,
    "examples": {
      "good": [
        "a majestic mountain landscape at golden hour, photorealistic",
        "abstract art with vibrant colors, modern style"
      ],
      "bad": [
        "placeholder text"
      ]
    }
  }
}